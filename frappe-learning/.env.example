# Copy to .env and set your values
# cp .env.example .env

# Database (MariaDB)
MYSQL_ROOT_PASSWORD=your_mysql_root_password
DB_PASSWORD=your_db_password

# Site admin (Frappe)
SITE_ADMIN_PASSWORD=admin

# Optional: for external DB (uncomment and set when using external MariaDB)
# DB_HOST=10.30.0.2
# DB_PORT=3306
# DB_NAME=lms_db
# DB_USER=vgi_skill
# DB_PASSWORD=your_db_password

# Custom apps path (default: sibling folder)
CUSTOM_APPS_PATH=../frappe-custom-apps
