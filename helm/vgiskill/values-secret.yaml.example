# Or run: python scripts/generate-values-secret-from-env.py
#
# cp values-secret.yaml.example values-secret.yaml
# Then edit values-secret.yaml

frappe:
  siteAdminPassword: "admin"

  db:
    host: "your_db_host"
    port: 3306
    name: "your_db_name"
    user: "your_db_user"
    password: "your_db_password"
